---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { fontsPageStrings } from "../i18n/translations";

// Default to English for the main fonts.html
const t = fontsPageStrings.en;
---

<Layout lang={t.lang} title={t.title}>
  <header class="site-header">
    <div class="container">
      <nav class="nav">
        <a href="/" class="nav-brand">Font Manager</a>
        <div class="nav-links">
          <a href="/">{t.backToHome}</a>
          <a
            href="https://github.com/otoneko1102/font-manager"
            target="_blank"
            class="github-link"
          >
            <Icon name="simple-icons:github" width="18" height="18" />
            GitHub
          </a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero" style="padding: 48px 0 32px;">
      <div class="container">
        <h1>{t.heading}</h1>
        <p class="hero-tagline">{t.description}</p>
      </div>
    </section>

    <div class="container">
      <div class="fonts-toolbar">
        <div class="search-box">
          <Icon name="lucide:search" class="search-icon" width="18" height="18" />
          <input
            type="text"
            id="font-search"
            placeholder={t.searchPlaceholder}
          />
        </div>
        <div class="font-count-badge">
          <span class="font-count-label">{t.totalFonts}</span>
          <span class="font-count-number" id="number">...</span>
        </div>
      </div>

      <div class="fonts-grid" id="fonts-grid"></div>

      <p id="no-results" class="no-results" style="display:none;">
        No results found.
      </p>
    </div>
  </main>

  <style is:global>
    .fonts-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 24px;
      flex-wrap: wrap;
    }

    .search-box {
      position: relative;
      flex: 1;
      max-width: 400px;
    }

    .search-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-secondary);
      pointer-events: none;
    }

    .search-box input {
      width: 100%;
      padding: 12px 16px 12px 44px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--bg-card);
      color: var(--text-primary);
      font-family: var(--font);
      font-size: 0.9rem;
      outline: none;
      transition: all 0.2s;
    }

    .search-box input::placeholder {
      color: var(--text-secondary);
    }

    .search-box input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }

    .fonts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px;
    }

    .font-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
      transition: all 0.25s;
      animation: fadeIn 0.4s ease-out both;
    }

    .font-card:hover {
      background: var(--bg-card-hover);
      border-color: rgba(108, 92, 231, 0.3);
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    }

    .font-card .font-name {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 4px;
      transition: font-family 0.3s ease;
    }

    .font-card .font-preview {
      font-size: 1.2rem;
      color: var(--text-secondary);
      margin-bottom: 8px;
      min-height: 1.6em;
      transition: font-family 0.3s ease;
    }

    .font-card .font-ext {
      font-size: 0.75rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .no-results {
      text-align: center;
      color: var(--text-secondary);
      padding: 48px 0;
      font-size: 1rem;
    }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", async () => {
      const numberEl = document.getElementById("number");
      const grid = document.getElementById("fonts-grid");
      const searchInput = document.getElementById(
        "font-search",
      ) as HTMLInputElement;
      const noResults = document.getElementById("no-results");
      if (!numberEl || !grid || !searchInput || !noResults) return;

      let allFonts: { name: string; ext: string; file: string }[] = [];

      const FONT_BASE =
        "https://raw.githubusercontent.com/otoneko1102/font-manager/main/fonts/";
      const loadedFonts = new Set<string>();

      // Lazy-load fonts as cards scroll into view
      const fontObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const card = entry.target as HTMLElement;
            const file = card.dataset.fontFile;
            if (!file || loadedFonts.has(file)) continue;
            loadedFonts.add(file);
            const name = file.replace(/\.(ttf|otf|woff2?)$/i, "");
            const face = new FontFace(
              `FP_${name}`,
              `url('${FONT_BASE}${encodeURIComponent(file)}')`,
            );
            face
              .load()
              .then(() => document.fonts.add(face))
              .catch(() => {});
          }
        },
        { rootMargin: "200px" },
      );

      try {
        const res = await fetch(
          "https://raw.githubusercontent.com/otoneko1102/font-manager/main/fonts.json",
        );
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const json = await res.json();

        if (!json.fonts || !Array.isArray(json.fonts))
          throw new Error("Invalid");

        allFonts = json.fonts.map((f: string) => {
          const dotIdx = f.lastIndexOf(".");
          return {
            file: f,
            name: dotIdx >= 0 ? f.substring(0, dotIdx) : f,
            ext: dotIdx >= 0 ? f.substring(dotIdx) : "",
          };
        });

        numberEl.textContent = String(allFonts.length);
        renderFonts(allFonts);
      } catch (err) {
        numberEl.textContent = "—";
        console.error("Font fetch error:", err);
      }

      searchInput.addEventListener("input", () => {
        const query = searchInput.value.toLowerCase().trim();
        const filtered = allFonts.filter((f) =>
          f.name.toLowerCase().includes(query),
        );
        renderFonts(filtered);
        noResults.style.display = filtered.length === 0 ? "block" : "none";
      });

      function renderFonts(
        fonts: { name: string; ext: string; file: string }[],
      ) {
        grid!.innerHTML = fonts
          .map(
            (f, i) =>
              `<div class="font-card" data-font-file="${f.file}" style="animation-delay: ${Math.min(i * 20, 600)}ms">
                <div class="font-name" data-font-preview style="font-family: 'FP_${f.name}', sans-serif !important">${f.name}</div>
                <div class="font-preview" data-font-preview style="font-family: 'FP_${f.name}', sans-serif !important">AaBbCc 123 あア</div>
                <div class="font-ext">${f.ext}</div>
              </div>`,
          )
          .join("");

        // Observe new cards for lazy font loading
        grid!
          .querySelectorAll(".font-card[data-font-file]")
          .forEach((el) => fontObserver.observe(el));
      }
    });
  </script>
</Layout>
