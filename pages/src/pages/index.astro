---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { indexStrings, languageLinks } from "../i18n/translations";

const featureIcons = ["🔤", "📤", "🌐", "🔄"];
---

<Layout lang={indexStrings.lang} title={indexStrings.title}>
  <header class="site-header">
    <div class="container">
      <nav class="nav">
        <a href="/" class="nav-brand">Font Manager</a>
        <div class="nav-links">
          <a href="fonts.html">{indexStrings.viewAllFonts}</a>
          <a
            href="https://github.com/otoneko1102/font-manager"
            target="_blank"
            class="github-link"
          >
            <Icon name="simple-icons:github" width="18" height="18" />
            GitHub
          </a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container">
        <div class="hero-badge">Chrome Extension</div>
        <h1>{indexStrings.heading}</h1>
        <p class="hero-tagline">{indexStrings.heroTagline}</p>
        <div class="hero-actions">
          <a
            href="https://chromewebstore.google.com/detail/mgpehaaemcemgmipcaaclkkmhgllchho"
            target="_blank"
            class="btn btn-primary"
          >
            <Icon name="simple-icons:googlechrome" width="18" height="18" />
            {indexStrings.installFromStore}
          </a>
          <a
            href="https://github.com/otoneko1102/font-manager"
            target="_blank"
            class="btn btn-ghost"
          >
            <Icon name="simple-icons:github" width="18" height="18" />
            GitHub
          </a>
          <a href="fonts.html" class="btn btn-ghost"
            >{indexStrings.viewAllFonts}</a
          >
        </div>
      </div>
    </section>

    <div class="container">
      <section class="features">
        {
          indexStrings.features.map((feat, i) => (
            <div class="feature-card">
              <div class="feature-icon">{featureIcons[i]}</div>
              <p>{feat}</p>
            </div>
          ))
        }
      </section>
    </div>

    <section class="font-marquee-section">
      <div class="font-marquee-header">
        <div class="font-count-badge">
          <span class="font-count-label">{indexStrings.fontCount}</span>
          <span class="font-count-number" id="number">...</span>
        </div>
      </div>
      <div class="marquee-container">
        <div class="marquee-track" id="marquee-row-1"></div>
        <div class="marquee-track marquee-track-reverse" id="marquee-row-2">
        </div>
      </div>
      <div class="view-all-link">
        <a href="fonts.html">{indexStrings.viewAllFonts}</a>
      </div>
    </section>

    <div class="container">
      <section class="section">
        <div class="info-card">
          <p>{indexStrings.description}</p>
          <p>{indexStrings.detail}</p>
          <p>{indexStrings.comfort}</p>
          <p>{indexStrings.looking}</p>
          <p><Fragment set:html={indexStrings.fontRequests} /></p>
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">{indexStrings.supportedLanguages}</h2>
        <ul class="lang-grid">
          {
            languageLinks.map((link) => (
              <li>
                <a href={`${link.code}.html`}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </main>

  <script>
    document.addEventListener("DOMContentLoaded", async () => {
      const numberEl = document.getElementById("number");
      const row1 = document.getElementById("marquee-row-1");
      const row2 = document.getElementById("marquee-row-2");
      if (!numberEl || !row1 || !row2) return;

      try {
        const res = await fetch(
          "https://raw.githubusercontent.com/otoneko1102/font-manager/main/fonts.json",
        );
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const json = await res.json();

        if (!json.fonts || !Array.isArray(json.fonts))
          throw new Error("Invalid JSON");

        const fonts: string[] = json.fonts.map((f: string) =>
          f.replace(/\.(ttf|otf|woff2?)$/i, ""),
        );
        numberEl.textContent = String(fonts.length);

        const mid = Math.ceil(fonts.length / 2);
        const row1Fonts = fonts.slice(0, mid);
        const row2Fonts = fonts.slice(mid);

        const makeItems = (arr: string[]) =>
          [...arr, ...arr]
            .map((f) => `<span class="marquee-item">${f}</span>`)
            .join("");
        row1.innerHTML = makeItems(row1Fonts);
        row2.innerHTML = makeItems(row2Fonts);
      } catch (err) {
        numberEl.textContent = "—";
        console.error("Font fetch error:", err);
      }
    });
  </script>
</Layout>
