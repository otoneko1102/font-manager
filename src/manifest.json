{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_Name__",
  "description": "__MSG_Description__",
  "permissions": [
    "storage",
    "tabs",
    "unlimitedStorage",
    "notifications",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/16x16.png",
    "48": "icons/48x48.png",
    "128": "icons/128x128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16x16.png",
      "48": "icons/48x48.png",
      "128": "icons/128x128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.ts"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.ts"
  },
  "web_accessible_resources": [
    {
      "resources": ["fonts.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
